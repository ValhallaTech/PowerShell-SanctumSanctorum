{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "psmodule": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.ps1$", "\\.psm1$"],
      "matchStrings": [
        "Install-Module\\s+-Name\\s+(?<depName>[\\w\\.]+)\\s+-(?:Required)?Version\\s+(?<currentValue>[\\d\\.]+)"
      ],
      "datasourceTemplate": "nuget",
      "registryUrlTemplate": "https://www.powershellgallery.com/api/v2"
    }
  ]
}
